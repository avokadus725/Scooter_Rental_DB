<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--
        USER_SERVICE: user_role junction table.
        Author: alona
        Branch: feature/user-service
    -->
    <changeSet id="003-create-user_role-table" author="alona">
        <createTable tableName="user_role" schemaName="dbo"
                     remarks="Many-to-many mapping between user and role">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_user_role"/>
            </column>
            <column name="user_id" type="INT">
                <constraints nullable="false"
                             foreignKeyName="FK_user_role_user"
                             references="dbo.[user](id)"/>
            </column>
            <column name="role_id" type="INT">
                <constraints nullable="false"
                             foreignKeyName="FK_user_role_role"
                             references="dbo.role(id)"/>
            </column>
        </createTable>

        <sql>CREATE UNIQUE INDEX UQ_user_role_user_role ON dbo.user_role (user_id, role_id);</sql>
        <sql>CREATE INDEX idx_user_role_user_id ON dbo.user_role (user_id);</sql>
        <sql>CREATE INDEX idx_user_role_role_id ON dbo.user_role (role_id);</sql>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES (
                'scooter_rental',
                'user_role',
                'DATA_TABLE',
                'alona',
                1,
                'USER_SERVICE',
                'Many-to-many mapping between user and role',
                (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('dbo.user_role')),
                SYSUTCDATETIME(),
                NULL
            );
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'user_role';</sql>
            <dropTable tableName="user_role" schemaName="dbo"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
