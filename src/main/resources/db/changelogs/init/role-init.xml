<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--
        USER_SERVICE: role table.
        Author: alona
        Branch: feature/user-service
    -->
    <changeSet id="001-create-role-table" author="alona">
        <createTable tableName="role" schemaName="dbo"
                     remarks="User roles dictionary (ADMIN, CUSTOMER, STAFF)">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="PK_role"/>
            </column>
            <column name="name" type="NVARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UQ_role_name"/>
            </column>
            <column name="description" type="NVARCHAR(256)"/>
        </createTable>

        <sql>CREATE INDEX idx_role_name ON dbo.role (name);</sql>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES (
                'scooter_rental',
                'role',
                'DICTIONARY',
                'alona',
                1,
                'USER_SERVICE',
                'User roles dictionary (ADMIN, CUSTOMER, STAFF)',
                (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('dbo.role')),
                SYSUTCDATETIME(),
                NULL
            );
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'role';</sql>
            <dropTable tableName="role" schemaName="dbo"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
